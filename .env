# Which Whisper model to load. Bigger = more accurate but slower and uses more RAM.
# tiny (~1GB, fastest, lowest accuracy), base (~1GB), small (~2GB), medium (~5GB), large-v3 (~10GB, slowest, best)
MODEL_SIZE=large-v3

# Language of the audio (ISO 639-1 code, e.g. en, de, fr).
# Leave blank for auto-detect (Whisper listens to the first few seconds and guesses).
WHISPER_LANGUAGE=en

# LM Studio connection
LLM_BASE_URL=http://localhost:1234/v1
LLM_MODEL=local-model
LLM_TIMEOUT=60
LLM_MODE=format
