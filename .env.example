# Which Whisper model to load. Bigger = more accurate but slower and uses more RAM.
# tiny (~1GB, fastest, lowest accuracy), base (~1GB), small (~2GB), medium (~5GB), large-v3 (~10GB, slowest, best)
MODEL_SIZE=large-v3

# Language of the audio (ISO 639-1 code, e.g. en, de, fr).
# Leave blank for auto-detect (Whisper listens to the first few seconds and guesses).
WHISPER_LANGUAGE=en

# LM Studio connection — used by format.py to post transcripts to a local LLM.
# LLM_BASE_URL: address of your running LM Studio server (default: http://localhost:1234/v1)
LLM_BASE_URL=http://localhost:1234/v1
# LLM_MODEL: model identifier sent in the request payload (LM Studio ignores it and uses whatever model is loaded in the UI)
LLM_MODEL=local-model
# LLM_TIMEOUT: seconds to wait for the LLM response — increase for large transcripts or slow models
LLM_TIMEOUT=60
# LLM_MODE: format = remove filler words and fix punctuation, keep meaning unchanged
#           summarize = condense transcript to key points
LLM_MODE=format
